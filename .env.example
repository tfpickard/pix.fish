# Neon Postgres (from Vercel integration or https://neon.tech)
POSTGRES_URL=

# Vercel Blob read/write token (from Vercel dashboard -> Storage -> Blob)
BLOB_READ_WRITE_TOKEN=

# Auth.js v5
# openssl rand -hex 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# GitHub OAuth App
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Numeric GitHub user id of the owner. Look it up at https://api.github.com/users/<username>
OWNER_GITHUB_ID=

# AI providers
ANTHROPIC_API_KEY=
# Optional in Phase 1 (default provider is Anthropic)
OPENAI_API_KEY=
